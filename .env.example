# ─── 도메인 ────────────────────────────────────────────────────────────────────
# VPS에 연결된 실제 도메인으로 변경
DOMAIN=example.com

# ─── 프로젝트 ──────────────────────────────────────────────────────────────────
PROJECT_NAME="중고거래 MVP"
ENVIRONMENT=production

# ─── 보안 ──────────────────────────────────────────────────────────────────────
# python -c "import secrets; print(secrets.token_urlsafe(32))" 로 생성
SECRET_KEY=CHANGE_THIS_TO_A_RANDOM_SECRET_KEY

# ─── 어드민 초기 계정 ──────────────────────────────────────────────────────────
FIRST_SUPERUSER=admin@example.com
FIRST_SUPERUSER_PASSWORD=CHANGE_THIS_TO_A_STRONG_PASSWORD

# ─── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_SERVER=db
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_THIS_TO_A_STRONG_DB_PASSWORD
POSTGRES_DB=marketplace

# ─── Google OAuth ──────────────────────────────────────────────────────────────
# Google Cloud Console → 사용자 인증 정보 → OAuth 2.0 클라이언트 ID
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ─── CORS ──────────────────────────────────────────────────────────────────────
# Flutter 앱은 별도 origin 없음 (네이티브 앱), admin은 HTTPS 도메인
BACKEND_CORS_ORIGINS="https://admin.example.com"

# ─── Cloudflare R2 ─────────────────────────────────────────────────────────────
# Cloudflare Dashboard → R2 → API 토큰
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=marketplace
# R2 버킷의 공개 URL (커스텀 도메인 또는 r2.dev 주소)
R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# ─── Firebase FCM ──────────────────────────────────────────────────────────────
# Firebase Console → 프로젝트 설정 → 서비스 계정 → JSON 키 파일 경로
FIREBASE_SERVICE_ACCOUNT_KEY=/run/secrets/firebase_key.json

# ─── 어드민 Next.js → 백엔드 API URL ──────────────────────────────────────────
# 컨테이너 내부에서 백엔드 호출 (서비스명 사용)
ADMIN_API_URL=http://backend:8000/api/v1

# ─── Sentry (선택) ─────────────────────────────────────────────────────────────
SENTRY_DSN=
