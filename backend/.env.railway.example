# ── Railway PostgreSQL 플러그인 변수 참조 ──────────────────────────────────────
# Railway 대시보드에서 PostgreSQL 플러그인 추가 후 아래처럼 참조 변수로 입력
POSTGRES_SERVER=${{Postgres.PGHOST}}
POSTGRES_PORT=${{Postgres.PGPORT}}
POSTGRES_USER=${{Postgres.PGUSER}}
POSTGRES_PASSWORD=${{Postgres.PGPASSWORD}}
POSTGRES_DB=${{Postgres.PGDATABASE}}

# ── 앱 설정 ──────────────────────────────────────────────────────────────────
PROJECT_NAME=중고마켓
ENVIRONMENT=production

# 32바이트 이상 랜덤 문자열 (python -c "import secrets; print(secrets.token_urlsafe(32))")
SECRET_KEY=여기에_랜덤_시크릿_키_입력

# Google OAuth (GCP Console에서 발급)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# 어드민 초기 계정
FIRST_SUPERUSER=admin@yourdomain.com
FIRST_SUPERUSER_PASSWORD=안전한_패스워드_입력

# ── CORS ─────────────────────────────────────────────────────────────────────
# 어드민 Vercel URL (배포 후 추가)
FRONTEND_HOST=https://your-admin.vercel.app
BACKEND_CORS_ORIGINS=https://your-admin.vercel.app

# ── Cloudflare R2 ─────────────────────────────────────────────────────────────
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key-id
R2_SECRET_ACCESS_KEY=your-secret-access-key
R2_BUCKET_NAME=marketplace
R2_PUBLIC_URL=https://your-r2-public-domain.com

# ── Firebase FCM ──────────────────────────────────────────────────────────────
# Firebase 서비스 계정 JSON을 한 줄로 압축해서 입력 (FCM 푸시 알림용)
# python -c "import json; print(json.dumps(json.load(open('firebase-key.json'))))"
# Railway 대시보드 → Variables → Add Variable → FIREBASE_CREDENTIALS_JSON
FIREBASE_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"..."}
